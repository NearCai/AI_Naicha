# Copy to .env and fill in
ANTHROPIC_API_KEY=
LOG_LEVEL=INFO

# Optional - if unset, system uses MockLLMPlanner
BEVERAGE_AI_USE_REAL_LLM=0

# -----------------------------------------------------------------------------
# FastAPI / v2 服务配置 (beverage_ai/api/main.py)
# -----------------------------------------------------------------------------
# DuckDB feedback 文件 + audit 输出目录 (默认 data/ 下)
# BEVERAGE_AI_FEEDBACK_DB=data/feedback.duckdb
# BEVERAGE_AI_AUDIT_DIR=data/feedback

# CORS — 生产必须设置之一,否则只允许 localhost:3000
# (1) 显式白名单 (逗号分隔):
# BEVERAGE_AI_CORS_ORIGINS=https://app.example.com,https://admin.example.com
# (2) 正则匹配 (支持任意子域):
# BEVERAGE_AI_CORS_ORIGIN_REGEX=^https://([a-z0-9-]+\.)*example\.com$
# (3) 全开放 (不推荐生产, 会强制关闭 credentials):
# BEVERAGE_AI_CORS_ORIGINS=*

# 携带 cookie / Authorization 头时打开 (默认 false)
# BEVERAGE_AI_CORS_ALLOW_CREDENTIALS=true
