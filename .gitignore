# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
.venv/
.venv_*/
venv/
env/
.env

# =============================================================================
# IDE / Editor
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# =============================================================================
# Testing / coverage
# =============================================================================
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.hypothesis/
coverage.xml
*.cover
.tox/
.nox/
.mypy_cache/
.ruff_cache/

# =============================================================================
# Models — too large for git, regeneratable from scripts/train_*.py
# =============================================================================
models/*.pt
models/*.pkl
models/*.pth
# Keep model training logs (small JSON) for reference
!models/*_log.json
!models/MANIFEST.yaml
!models/.gitkeep

# =============================================================================
# Data — keep schemas + small reference yaml, exclude generated / scraped
# =============================================================================

# Generated / large binary data
*.duckdb
*.duckdb.wal
*.parquet
*.feather
*.h5
*.hdf5
*.npy
*.npz

# Prior history snapshots (generated by closed-loop updates)
data/priors/prior_history/*.json
!data/priors/prior_history/.gitkeep

# Feedback / aspects caches (generated)
data/feedback.duckdb*
data/reviews/aspects_cache.duckdb*

# Raw scraped reviews (legal grey area + too large)
data/reviews/raw/*/raw_reviews.parquet
data/reviews/raw/*/*.csv

# Generated typical_serving overrides (output of update_from_feedback.py)
data/ingredients/typical_serving_overrides.yaml

# Update audit trails (per-session JSON)
data/feedback/update_session_*.json

# But ALWAYS keep:
#   data/ingredients/*.yaml         (vocab, aliases, keyword_aliases, topping_compat)
#   data/recipes/*.yaml             (reference recipes)
#   data/priors/*.yaml              (initial alpha, context deltas)
#   data/products/*.yaml + README   (sku features)
#   data/reviews/templates/         (CSV import template)

# =============================================================================
# Logs / temporary
# =============================================================================
*.log
*.tmp
*.bak
*.orig

# =============================================================================
# Notebooks
# =============================================================================
.ipynb_checkpoints/
*-checkpoint.ipynb

# =============================================================================
# Gradio
# =============================================================================
flagged/
gradio_cached_examples/

# =============================================================================
# Project-specific large outputs
# =============================================================================
release/
*.zip
